<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 使用属性定义日志路径 -->
    <property name="LOG_HOME" value="D:/service/BGI/node8030/log"/>

    <!-- 控制台输出 - 包含任务标识 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{task:-common}] [%method] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 按任务分离的INFO日志文件 -->
    <appender name="TASK_INFO_SEPARATED" class="ch.qos.logback.classic.sift.SiftingAppender">
        <discriminator>
            <key>task</key>
            <defaultValue>common</defaultValue>
        </discriminator>
        <sift>
            <!-- 为每个任务创建独立的INFO日志文件 -->
            <appender name="TASK_INFO-${task}" class="ch.qos.logback.core.rolling.RollingFileAppender">
                <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                    <!-- 直接使用日期模式创建日志文件，不使用file元素 -->
                    <fileNamePattern>${LOG_HOME}/${task}/info/${task}_info.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                    <maxFileSize>10MB</maxFileSize>
                    <maxHistory>15</maxHistory>
                    <totalSizeCap>500MB</totalSizeCap>
                </rollingPolicy>
                <!-- 过滤器：只记录INFO级别（不记录ERROR） -->
                <filter class="ch.qos.logback.classic.filter.LevelFilter">
                    <level>ERROR</level>
                    <onMatch>DENY</onMatch>
                    <onMismatch>NEUTRAL</onMismatch>
                </filter>
                <encoder>
                    <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%method] [%X{ip:-}] %-5level %logger{36} - %msg%n</pattern>
                </encoder>
            </appender>
        </sift>
    </appender>

    <!-- 按任务分离的ERROR日志文件 -->
    <appender name="TASK_ERROR_SEPARATED" class="ch.qos.logback.classic.sift.SiftingAppender">
        <discriminator>
            <key>task</key>
            <defaultValue>common</defaultValue>
        </discriminator>
        <sift>
            <!-- 为每个任务创建独立的ERROR日志文件 -->
            <appender name="TASK_ERROR-${task}" class="ch.qos.logback.core.rolling.RollingFileAppender">
                <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                    <!-- 直接使用日期模式创建日志文件，不使用file元素 -->
                    <fileNamePattern>${LOG_HOME}/${task}/error/${task}_error.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                    <maxFileSize>10MB</maxFileSize>
                    <maxHistory>15</maxHistory>
                    <totalSizeCap>500MB</totalSizeCap>
                </rollingPolicy>
                <!-- 过滤器：只记录ERROR级别 -->
                <filter class="ch.qos.logback.classic.filter.LevelFilter">
                    <level>ERROR</level>
                    <onMatch>ACCEPT</onMatch>
                    <onMismatch>DENY</onMismatch>
                </filter>
                <encoder>
                    <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%method] [%X{ip:-}] [%X{path:-}] %-5level %logger{36} - %msg%n</pattern>
                </encoder>
            </appender>
        </sift>
    </appender>

    <!-- 错误日志（所有任务的错误日志汇总） -->
    <appender name="GLOBAL_ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- 直接使用日期模式创建日志文件，不使用file元素 -->
            <fileNamePattern>${LOG_HOME}/global_error.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{task:-common}] [%X{ip:-}] [%X{path:-}] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 根日志配置 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="TASK_INFO_SEPARATED" />
        <appender-ref ref="TASK_ERROR_SEPARATED" />
        <appender-ref ref="GLOBAL_ERROR_FILE" />
    </root>
</configuration>